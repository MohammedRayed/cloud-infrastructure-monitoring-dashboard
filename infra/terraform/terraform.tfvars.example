aws_region = "us-east-1"

project_name = "cloud-monitoring-dashboard"

instance_type = "t3.small"

public_key_path = "~/.ssh/monitoring-dashboard-key.pub"

# Replace with your real public IP followed by /32
allowed_ssh_cidr        = "YOUR_PUBLIC_IP/32"
allowed_grafana_cidr    = "YOUR_PUBLIC_IP/32"
allowed_prometheus_cidr = "YOUR_PUBLIC_IP/32"
